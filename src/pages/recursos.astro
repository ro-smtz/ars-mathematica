---
import BaseLayout from "../layouts/BaseLayout.astro";
import CodeCard from "../components/CodeCard.astro";

import { getCollection } from "astro:content";

const resources = await getCollection("resources");

const codes = resources
  .filter((resource) => resource.data.category === "code")
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() -
      new Date(a.data.date).getTime()
  )
  .slice(0,5);
---

<BaseLayout title="Recursos — Ars Mathematica">

  <main class="container page">

    <h1>Recursos</h1>

    <p class="page-intro">
      Material descargable, código fuente y recursos utilizados
      en proyectos científicos y educativos.
    </p>

    <h2>Códigos completos</h2>

    <div class="codes-grid">
      {
        codes.length > 0 ? (
          codes.map((resource) => (
            <CodeCard
              title={resource.data.title}
              image={resource.data.image}
              date={resource.data.date}
              tags={resource.data.tags}
              link={resource.data.link}
              label={resource.data.label}
            />
          ))
        ) : (
          <p>En construcción...</p>
        ) 
      }
    </div>

    <a
      href="/ars-mathematica/recursos/codigos-completos"
      class="view-all"
    >
      Ver todos los códigos →
    </a>

    <h2>Plantillas</h2>

    <p>En construcción...</p>

    <h2>Notas</h2>

    <p>En construcción...</p>

    <h2>Material complementario</h2>

    <p>En construcción...</p>

  </main>

</BaseLayout>
---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { asset } from "../../utils/asset.ts";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const courses = await getCollection("courses");
  return courses.map((course) => ({
    params: { id: course.id },
  }));
}

const { id } = Astro.params;
const course = await getEntry("courses", id);

if (!course) {
  return Astro.redirect(asset("/cursos"));
}

const { Content } = await render(course);

const isOpen = course.data.status === "open";
const isComingSoon = course.data.status === "coming-soon";
const isArchived = course.data.status === "archived";
---

<BaseLayout title={`${course.data.title} — Ars Mathematica`}>

  <main class="container page">

    <section class="course-hero">

      <div class="course-hero-text">

        {
          isOpen && (
            <span class="course-status open">Inscripciones abiertas</span>
          )
        }

        {
          isComingSoon && (
            <span class="course-status coming-soon">Próximamente</span>
          )
        }

        {
          isArchived && (
            <span class="course-status archived">Curso archivado</span>
          )
        }

        <span class="course-meta">
          {course.data.code} · Nivel {course.data.level}
        </span>

        <h1>{course.data.title}</h1>

        <p class="course-summary">
          {course.data.summary}
        </p>

        <div class="course-facts">
          {isOpen && (
            <>
              <p>{course.data.dates}</p>
              <p>{course.data.modality}</p>
              <p>{course.data.schedule}</p>
            </>
          )}  
        </div>
        
        {isOpen && (
          <a
            href={course.data.cta_link}
            class="course-cta"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Solicitar inscripción por Whatsapp"
          >
            {course.data.cta_label}
          </a>
        )}

      </div>

      <div class="course-hero-image">
        <img
          src={asset(course.data.image)}
          alt={course.data.title}
        />
      </div>

    </section>

    <div class="course-content">
      <Content />
    </div>

    {(isOpen || isComingSoon) && (
    <div class="course-content">
      <h2> Acerca del instructor </h2>
      <section class="instructor-section">

        <img
          src={asset("/images/rodrigo.png")}
          alt="Rodrigo Sánchez-Martínez"
          class="instructor-photo"
        />
        
        <blockquote class="instructor-quote">
          <p>
            Mi nombre es <b>Rodrigo Sánchez-Martínez</b>, actual estudiante de doctorado
            y divulgador científico especializado en visualización de datos y comunicación
            científica.
          </p>
          <p>
            Aprendí LaTeX durante mi formación académica y desde entonces se ha convertido
            en mi herramienta principal para escribir artículos científicos, preparar material
            docente y desarrollar visualizaciones para investigación y divulgación.
          </p>

          <p class = "instructor-link">
            <a href={asset("/sobre")}>
              Conoce más sobre mi investigación y el proyecto Ars Mathematica →
            </a>
          </p>
        </blockquote>

      </section>
    </div>
    )}

    {isOpen && course.data.pricing && (
      <section class="pricing-section">

        <h2>Costos de inscripción</h2>

        <p>
          Mi objetivo es que cualquier estudiante o investigador interesado pueda comenzar a utilizar LaTeX de manera práctica.
          Por ello, se ofrecen distintas modalidades de inscripción según las necesidades de cada participante.
        </p>

        <div class="pricing-grid">

          {course.data.pricing.map((plan) => (
            <div class="pricing-card">

              <h3>{plan.title}</h3>

              <div class="pricing-price">
                ${plan.price_mxn} MXN
              </div>
              
              {
                plan.price_usd && (
                  <div class="pricing-price-usd">
                    ≈ {plan.price_usd} USD
                  </div>
                )
              }

              <p>{plan.description}</p>

            </div>
          ))}

        </div>

        <p class="pricing-note">
          Los precios en USD son aproximados y se muestran únicamente como referencia.
          Si tienes alguna duda o alguna dificultad para cubrir el costo de inscripción, no dudes en contactarme.
        </p>

      </section>
    )}

    {isOpen && (
      <section class="payment-section">

        <h2>Formas de pago</h2>

        <ul>
          <li>
            <strong>México:</strong>
            depósito o transferencia bancaria.
          </li>

          <li>
            <strong>Extranjero:</strong>
            pago mediante PayPal.
          </li>
        </ul>

      </section>
    )}

    {isOpen &&(
      <section class="enrollment-section">

        <h2>¿Deseas participar en esta edición?</h2>

        <p>
          Si tienes alguna duda sobre horarios,
          pagos o requisitos, puedes escribirme directamente.
        </p>

        <a
          href={course.data.cta_link}
          class="course-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          {course.data.cta_label}
        </a>

      </section>
    )}

  </main>

</BaseLayout>
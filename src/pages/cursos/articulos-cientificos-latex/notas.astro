---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const entry = await getEntry("notes", "articulos-cientificos-latex");
if (!entry) throw new Error("No se encontró el archivo de notas.");

const { Content, headings } = await render(entry);

const filteredHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={entry.data.title}>
  <div class="notes-layout container">
    <aside class="notes-toc" id="notes-toc">
      <p class="notes-toc-title">Contenido</p>
      <nav>
        <ul class="notes-toc-list">
          {filteredHeadings.map(h => (
            <li class={`notes-toc-item depth-${h.depth}`}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
          <li class="notes-toc-item notes-toc-top">
            <a href="#top">Volver al inicio ↑</a>
          </li>
        </ul>
      </nav>
    </aside>

    <button class="notes-toc-toggle" id="notes-toc-toggle" aria-label="Abrir índice">Contenido</button>

    <main class="notes-content">
      <h1 id="top">{entry.data.title}</h1>
      <div class="course-content">
        <Content />
      </div>
    </main>
  </div>

  <script>
    const toc = document.getElementById("notes-toc");
    const toggle = document.getElementById("notes-toc-toggle");

    function openToc() {
      toc?.classList.add("is-open");
    }

    function closeToc() {
      toc?.classList.remove("is-open");
    }

    toggle?.addEventListener("click", (e) => {
      e.stopPropagation();
      toc?.classList.contains("is-open") ? closeToc() : openToc();
    });

    document.addEventListener("click", (e) => {
      if (!toc?.contains(e.target as Node)) {
        closeToc();
      }
    });

    toc?.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", closeToc);
    });
  </script>
</BaseLayout>
---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CodeCard from "../../components/CodeCard.astro";
import { asset } from "../../utils/asset";

const resources = await getCollection("resources");
const codes = resources
  .filter((resource) => resource.data.category === "code")
  .sort(
    (a, b) =>
      new Date(b.data.date).getTime() -
      new Date(a.data.date).getTime()
  );

const allTags = [
  "Todos",
  ...new Set(
    codes.flatMap((code) => code.data.tags)
  ),
].sort((a, b) => {
  if (a === "Todos") return -1;
  if (b === "Todos") return 1;
  return a.localeCompare(b);
});
const tagCount = allTags.length - 1; // subtract "Todos"
---

<BaseLayout
  title="Códigos completos — Ars Mathematica"
  description="Códigos fuente anotados de figuras científicas en LaTeX y TikZ. Descarga, estudia y adapta ejemplos reales para tus propios documentos y presentaciones."
>

  <main class="container page">

    <a
        href={asset("/recursos")}
        class="back-link"
        >
        ← Regresar a recursos
    </a>

    <h1>Códigos completos</h1>

    <div class="resource-stats">

        <div class="resource-stat">
            <strong>{codes.length}</strong>
            <span>
            {codes.length === 1
                ? "código disponible"
                : "códigos disponibles"}
            </span>
        </div>

        <div class="resource-stat">
            <strong>{tagCount}</strong>
            <span>
            {allTags.length === 1
                ? "categoría"
                : "categorías"}
            </span>
        </div>

        {codes.length > 0 && (
            <div class="resource-stat">
                <strong>
                {
                    new Date(codes[0].data.date).toLocaleDateString(
                    "es-MX",
                    {
                        day: "numeric",
                        month: "short",
                        year: "numeric",
                    }
                    )
                }
                </strong>
                <span>última actualización</span>
            </div>
        )}
    </div>

    <div class="page-intro">
        <p>
            Aquí podrás encontrar códigos completos de algunos diagramas que he realizado con TikZ, PGFPlots y ChemFig.
        </p>

        <p>
            <b>Todos aprendemos por imitación:</b> te invito a ver los códigos, descargarlos, estudiarlos y sobre todo, a modificarlos.
            La mejor manera de aprender a utilizar TikZ es experimentar con los comandos y observar cómo cambian los resultados al alterar cada uno de ellos.
        </p>
        
        <p>
            Muchos de los recursos compartidos aquí nacieron como ejercicios personales, ejemplos para cursos o figuras para mi
            <a href="https://www.instagram.com/ars_mathematica/" target="_blank"><b>página de Instagram</b></a>.
            Espero que puedan servirte como punto de partida para tus propios dibujos, gráficas y diagramas.
        </p>

        <p> 
            Y si en algún momento realizas una figura inspirada en alguno de estos códigos, no dudes en compartirla conmigo.
            Me encantaría verla.
        </p> 

        <blockquote>
            Nulla dies sine linea.
        </blockquote>
    </div>

    <h3> Explorar por categorías </h3>
    <div class="tags-cloud" id="tags-cloud">
        {
            allTags.map((tag) => (
            <button
                type="button"
                class={`tag-pill${tag === "Todos" ? " active" : ""}`}
                data-tag={tag}
                aria-pressed={tag === "Todos" ? "true" : "false"}
            >
                {tag}
            </button>
            ))
        }
    </div>

    <h2 id="codes-heading">Todos los códigos </h2>
    <div class="codes-grid" id="codes-grid">
    {
        codes.length > 0 ? (
        codes.map((resource) => (
            <div
              class="code-card-wrapper"
              data-tags={JSON.stringify(resource.data.tags)}
            >
              <CodeCard
                title={resource.data.title}
                image={resource.data.image}
                date={resource.data.date}
                tags={resource.data.tags}
                link={resource.data.link}
                label={resource.data.label}
              />
            </div>
        ))
        ) : (
        <p>En construcción...</p>
        ) 
    }
    </div>
    <p class="codes-empty" id="codes-empty" hidden>
        No hay códigos en esa categoría todavía.
    </p>

  </main>

</BaseLayout>

<script>
  const cloud   = document.getElementById("tags-cloud")    as HTMLElement;
  const grid    = document.getElementById("codes-grid")    as HTMLElement;
  const heading = document.getElementById("codes-heading") as HTMLElement;
  const empty   = document.getElementById("codes-empty")   as HTMLElement;
 
  if (cloud && grid) {
    const pills    = cloud.querySelectorAll<HTMLButtonElement>(".tag-pill");
    const wrappers = grid.querySelectorAll<HTMLElement>(".code-card-wrapper");
 
    function applyFilter(activeTag: string) {
      // Update pill states
      pills.forEach((pill) => {
        const isActive = pill.dataset.tag === activeTag;
        pill.classList.toggle("active", isActive);
        pill.setAttribute("aria-pressed", String(isActive));
      });
 
      // Show/hide cards
      let visibleCount = 0;
      wrappers.forEach((wrapper) => {
        const tags: string[] = JSON.parse(wrapper.dataset.tags ?? "[]");
        const visible = activeTag === "Todos" || tags.includes(activeTag);
        wrapper.hidden = !visible;
        if (visible) visibleCount++;
      });
 
      // Update heading and empty state
      if (heading) {
        heading.textContent =
          activeTag === "Todos"
            ? "Todos los códigos"
            : `Códigos de ${activeTag}`;
      }
      if (empty) empty.hidden = visibleCount > 0;
    }
 
    cloud.addEventListener("click", (e) => {
      const pill = (e.target as HTMLElement).closest<HTMLButtonElement>(".tag-pill");
      if (!pill?.dataset.tag) return;
      applyFilter(pill.dataset.tag);
    });
  }
</script>
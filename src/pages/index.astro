---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeatureCard from "../components/FeatureCard.astro";
import NewsCard from "../components/NewsCard.astro";
import { asset } from "../utils/asset.ts";
import { getCollection } from "astro:content";

const featuredFigures = (await getCollection("figures")).filter(
  (f) => f.data.featured === true
);

const news = await getCollection("news");

news.sort(
  (a, b) =>
    b.data.date.getTime() -
    a.data.date.getTime()
);

const latestNews = news.slice(0, 5);
---

<BaseLayout
  title="Ars Mathematica"
  description="Proyecto de comunicación científica en español. Cursos, tutoriales y recursos de LaTeX, TikZ y PGFPlots para estudiantes de física, matemáticas y química."
>

  <main class="container hero">

    <img
      src={asset("/logo_complete.svg")}
      alt="Ars Mathematica logo"
      class="logo"
    />

    <h1 class="hero-title">Ars Mathematica</h1>

    <p class="subtitle">
      Visualización científica con LaTeX
    </p>

    <p class="mantra">
      Non docentibus, sed discentibus;<br />
      Non eruditis, sed erudiendis.
    </p>

    <section class="container manifesto">
      <p>
        ¡Bienvenidos al sitio oficial del projecto Ars Mathematica!
        Aquí encontrarás cursos, tutoriales y recursos para aprender a comunicar
        ciencia con precisión y elegancia, usando LaTeX como herramienta principal.
      </p>
    </section>    
  </main>

  <section class="container features">
    <FeatureCard
      title="Cursos"
      href={asset("/cursos")}
      description="Formación especializada en TikZ, PGFPlots y escritura científica con LaTeX."
    />
    <FeatureCard
      title="Tutoriales"
      href={asset("/tutoriales")}
      description="Guías paso a paso sobre visualización científica con TikZ y PGFplots."
    />
    <FeatureCard
      title="Recursos"
      href={asset("/recursos")}
      description="Material de utilidad para aprender LaTeX, física y matemáticas."
    />
  </section>

  <section class="news-home">

    <h2 class="section-title">
      Novedades recientes
    </h2>

    {
      latestNews.map((entry) => (
        <NewsCard
          entry={entry}
        />
      ))
    }

    <a
      href={asset("/noticias")}
      class="view-all"
    >
      Ver todas las novedades →
    </a>

  </section>

    <section class="container instagram-home">

      <h2 class="section-title">
        Ars Mathematica en Instagram
      </h2>

      <div class="instagram-profile">

        <div class="instagram-avatar-column">
          <a
            href="https://instagram.com/ars_mathematica"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src={asset("/images/rodrigo-profile-picture.png")}
              alt="Ars Mathematica"
              class="instagram-avatar"
            />
          </a>
        </div>

        <div class="instagram-info-column">

          <a
            href="https://instagram.com/ars_mathematica"
            target="_blank"
            rel="noopener noreferrer"
          >
            <h3 class="instagram-handle">
              @ars_mathematica
            </h3>
          </a>
          
          <a
            href="https://instagram.com/ars_mathematica"
            target="_blank"
            rel="noopener noreferrer"
          >
            <h4 class="instagram-name">
              Rodrigo Sánchez | Visualización científica
            </h4>
          </a>

          <div class="instagram-stats">

            <div class="instagram-stat">
              <strong>170</strong>
              <span>Publicaciones</span>
            </div>

            <div class="instagram-stat">
              <strong>72.4K</strong>
              <span>Seguidores</span>
            </div>

            <div class="instagram-stat">
              <strong>261</strong>
              <span>Seguidos</span>
            </div>

          </div>

          <p class="instagram-bio">
            Física · Matemáticas · Química
            <br />
            Divulgación científica mediante ilustraciones.
            <br />
            TikZ · LaTeX
          </p>
        </div>
      </div>

      <p>
        Ars Mathematica nació durante los últimos meses de mi licenciatura en física.
        Mientras escribía mi tesis, me di cuenta de que las figuras que utilizaba provenían de programas distintos y tenían estilos gráficos completamente diferentes entre sí.
        Aunque el contenido era correcto, sentía que la presentación visual no reflejaba el cuidado que había puesto en el resto del trabajo.  
      </p>

      <p>
        Buscando una solución descubrí la paquetería de TikZ: eso cambió completamente mi manera de construir ilustraciones científicas.
        Lo que comenzó como una herramienta para mejorar mis documentos terminó convirtiéndose en un pasatiempo.
        Poco tiempo después abrí una pequeña cuenta de Instagram para compartir algunos de esos dibujos y registrar mi progreso.
      </p>

      <p>
        Nunca imaginé que ese proyecto personal crecería hasta convertirse en una comunidad de miles de personas interesadas en la ciencia y en la visualización científica.
        Hoy Ars Mathematica es al mismo tiempo un espacio de divulgación científica en español y una plataforma desde la que comparto un poco de lo que sé sobre TikZ, PGFplots y LaTeX.
      </p>

      {featuredFigures.length > 0 && (
        <h3 class="instagram-subtitle">
          Publicaciones destacadas
        </h3>

        <div class="figures-grid">
          {featuredFigures.map((fig) => (
            <div class="figure-card">
              <img src={asset(fig.data.image)} alt={fig.data.title} />
              <p class="figure-title">{fig.data.title}</p>
              <p class="figure-description">{fig.data.description}</p>
              {fig.data.instagram && (
                <a
                  href={fig.data.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="instagram-link"
                >
                  Ver en Instagram ↗
                </a>
              )}
            </div>
          ))}
        </div>
      )}

      <a
        href="https://instagram.com/ars_mathematica"
        target="_blank"
        rel="noopener noreferrer"
        class="view-all"
      >
        Ver perfil completo →
      </a>

    </section>

</BaseLayout>
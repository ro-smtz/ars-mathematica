---
import BaseLayout from "../layouts/BaseLayout.astro";
import CourseCard from "../components/CourseCard.astro";
import { asset } from "../utils/asset.ts";
import { families } from "../utils/families.ts";
import { getCollection } from "astro:content";

const allCourses = (await getCollection("courses")).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<BaseLayout title="Cursos — Ars Mathematica">

  <main class="container page">

    <div class="cursos-header">
      <h1>Cursos</h1>
      <p class="cursos-intro">
        Formación especializada en visualización y comunicación científica con LaTeX.
        Cada curso está diseñado desde la práctica: aprendes dibujando, graficando
        y escribiendo ciencia real.
      </p>
    </div>

    {families.map(({ key, label, description }) => {
      const courses = allCourses.filter((c) => c.data.family === key);
      if (courses.length === 0) return null;
      return (
        <section class="family-section">
          <div class="family-header">
            <h2 class="family-title">{label}</h2>
            <p class="family-description">{description}</p>
          </div>
          <div class="courses-grid">
            {courses.map((course) => (
              <CourseCard
                title={course.data.title}
                code={course.data.code}
                level={course.data.level}
                summary={course.data.summary}
                image={course.data.image}
                href={asset(`/cursos/${course.id}`)}
              />
            ))}
          </div>
        </section>
      );
    })}

  </main>

</BaseLayout>
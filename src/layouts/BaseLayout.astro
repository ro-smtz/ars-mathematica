---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

const { title = "Ars Mathematica" } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<html lang="es">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <meta name="description" content="Visualización científica con LaTeX. Cursos, tutoriales y figuras." />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Visualización científica con LaTeX. Cursos, tutoriales y figuras." />
    <meta property="og:image" content={`https://ro-smtz.github.io${base}/images/og-image.png`} />
    <meta property="og:url" content={`https://ro-smtz.github.io${base}`} />
    <meta property="og:type" content="website" />

    <link rel="icon" type="image/svg+xml" href="/logo.svg" />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />

    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Libre+Baskerville:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />
    <Footer />
  </body>
</html>